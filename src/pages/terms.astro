<style>
    :root {
        --bg-primary: #021F1C;
        --bg-deep: #021F1C;
        --bg-secondary: #032B27;
        --text-primary: #F4F2EC;
        --text-secondary: #B9C1BB;
        --text-subtle: #8C9690;
        --accent: #A9C3B1;
        --accent-light: #C7D9CD;
        --border: rgba(190, 230, 200, 0.16);
        --glass: rgba(255, 255, 255, 0.045);
        --font-serif: 'EB Garamond', Georgia, serif;
        --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--bg-primary); color: var(--text-primary); font-family: var(--font-sans); -webkit-font-smoothing: antialiased; }
    .shell { margin: 0 auto; width: min(960px, calc(100% - 48px)); }
    .site-header, .site-footer { background: var(--bg-primary); padding: 10px 0; }
    .nav-inner, .footer-inner { align-items: center; display: flex; gap: 24px; justify-content: space-between; }
    .logo { align-items: center; display: inline-flex; text-decoration: none; transition: transform 180ms ease; }
    .logo:hover { transform: translateY(-2px); }
    .logo img { display: block; height: 48px; object-fit: contain; width: auto; }
    .nav-link, .footer-links a, .site-footer p { color: var(--text-secondary); font-size: 13px; font-weight: 700; text-decoration: none; }
    .nav-link, .footer-links a { transition: color 160ms ease, transform 160ms ease; }
    .nav-link:hover, .footer-links a:hover { color: var(--text-primary); transform: translateY(-2px); }
    .page { padding: 96px 0; }
    .card { background: var(--glass); border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 28px 70px rgba(0,0,0,0.22); padding: 52px; transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease; }
    .card:hover { border-color: rgba(199,217,205,0.34); box-shadow: 0 38px 96px rgba(0,0,0,0.28); transform: translateY(-5px); }
    .eyebrow { color: var(--accent); font-size: 12px; font-weight: 800; letter-spacing: 0.12em; margin-bottom: 16px; text-transform: uppercase; }
    h1 { color: var(--text-primary); font-family: var(--font-serif); font-size: clamp(42px, 6vw, 68px); font-weight: 500; line-height: 1; margin-bottom: 14px; }
    h2 { color: var(--text-primary); font-family: var(--font-serif); font-size: 30px; font-weight: 500; margin: 34px 0 10px; }
    p { color: var(--text-secondary); line-height: 1.65; margin-top: 12px; }
    ul { color: var(--text-secondary); display: grid; gap: 8px; line-height: 1.6; margin: 14px 0 0 22px; }
    li::marker { color: var(--accent); }
    strong { color: var(--text-primary); }
    a { color: var(--accent-light); font-weight: 800; transition: color 160ms ease, transform 160ms ease; }
    .card a:hover { color: var(--text-primary); display: inline-block; transform: translateY(-2px); }
    .updated { color: var(--accent); font-size: 13px; font-weight: 800; margin-bottom: 24px; text-transform: uppercase; }
    .legal-emphasis { background: rgba(6,47,42,0.62); border: 1px solid var(--border); border-radius: 8px; color: var(--text-primary); font-size: 14px; font-weight: 800; letter-spacing: 0.02em; padding: 18px; }
    .legal-note { border-top: 1px solid var(--border); color: var(--accent-light); font-weight: 800; margin-top: 34px; padding-top: 22px; }
    .footer-links { display: flex; gap: 18px; }
    @media (max-width: 700px) { .nav-inner, .footer-inner { align-items: flex-start; flex-direction: column; } .logo img { height: 40px; } .card { padding: 34px; } }
</style>
